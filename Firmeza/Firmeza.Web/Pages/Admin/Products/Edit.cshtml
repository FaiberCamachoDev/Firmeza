@page "{id:int}"
@model Firmeza.Web.Pages.Admin.Products.EditModel
@{
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Editar Producto";
}

<div class="max-w-2xl">
    <a asp-page="Index" class="text-sm text-indigo-600 hover:text-indigo-800 mb-4 inline-block">← Volver a productos</a>

    <div class="card">
        <form method="post">
            <input type="hidden" asp-for="Input.Id" />
            <div asp-validation-summary="ModelOnly" class="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700"></div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="sm:col-span-2">
                    <label asp-for="Input.Name" class="form-label"></label>
                    <input asp-for="Input.Name" class="form-input" />
                    <span asp-validation-for="Input.Name" class="text-xs text-red-500 mt-1 block"></span>
                </div>

                <div class="sm:col-span-2">
                    <label asp-for="Input.Description" class="form-label"></label>
                    <textarea asp-for="Input.Description" class="form-input" rows="3"></textarea>
                </div>

                <div>
                    <label asp-for="Input.Category" class="form-label"></label>
                    <input asp-for="Input.Category" class="form-input" />
                </div>

                <div>
                    <label asp-for="Input.Unit" class="form-label"></label>
                    <input asp-for="Input.Unit" class="form-input" />
                    <span asp-validation-for="Input.Unit" class="text-xs text-red-500 mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="Input.Price" class="form-label"></label>
                    <input asp-for="Input.Price" type="number" step="0.01" min="0.01" class="form-input" />
                    <span asp-validation-for="Input.Price" class="text-xs text-red-500 mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="Input.StockInput" class="form-label">Stock</label>
                    <input asp-for="Input.StockInput" class="form-input" />
                    @if (Model.StockError != null)
                    {
                        <p class="text-xs text-red-500 mt-1">@Model.StockError</p>
                    }
                </div>

                <div class="flex items-center gap-2">
                    <input asp-for="Input.IsActive" type="checkbox" class="w-4 h-4 accent-indigo-600" />
                    <label asp-for="Input.IsActive" class="text-sm text-gray-700">Producto activo</label>
                </div>
            </div>

            <div class="flex gap-3 mt-6">
                <button type="submit" class="btn-primary">Guardar cambios</button>
                <a asp-page="Index" class="btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
