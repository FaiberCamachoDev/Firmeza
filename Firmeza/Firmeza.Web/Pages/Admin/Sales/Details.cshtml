@page "{id:int}"
@model Firmeza.Web.Pages.Admin.Sales.DetailsModel
@{
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = $"Venta #{Model.Sale.Id:D6}";

    decimal subtotal = Model.Sale.Details.Sum(d => d.Quantity * d.UnitPrice);
    decimal iva      = Math.Round(subtotal * 0.16m, 2);
    decimal total    = subtotal + iva;
}

<div class="max-w-2xl">
    <div class="flex items-center justify-between mb-4">
        <a asp-page="Index" class="text-sm text-indigo-600 hover:underline">← Volver a ventas</a>
        <div class="flex gap-2">
            @if (Model.ReceiptPath != null)
            {
                <a href="@Model.ReceiptPath" target="_blank" class="btn-primary text-sm">
                    Descargar recibo PDF
                </a>
            }
            <form method="post" asp-page-handler="Regenerate" asp-route-id="@Model.Sale.Id">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-secondary text-sm">
                    @(Model.ReceiptPath != null ? "Regenerar PDF" : "Generar PDF")
                </button>
            </form>
        </div>
    </div>

    <!-- Sale + Customer info -->
    <div class="grid grid-cols-2 gap-4 mb-4">
        <div class="card">
            <h3 class="text-sm font-semibold text-gray-700 mb-3">Datos de la venta</h3>
            <dl class="space-y-1 text-sm">
                <div class="flex justify-between">
                    <dt class="text-gray-500">N° Venta</dt>
                    <dd class="font-mono font-medium">#@Model.Sale.Id.ToString("D6")</dd>
                </div>
                <div class="flex justify-between">
                    <dt class="text-gray-500">Fecha</dt>
                    <dd>@Model.Sale.CreatedAt.ToString("dd/MM/yyyy HH:mm")</dd>
                </div>
                <div class="flex justify-between">
                    <dt class="text-gray-500">Estado</dt>
                    <dd>
                        <span class="@(Model.Sale.Status == "Completado" ? "badge-active" : "badge-inactive")">
                            @Model.Sale.Status
                        </span>
                    </dd>
                </div>
                @if (!string.IsNullOrEmpty(Model.Sale.Notes))
                {
                    <div class="pt-1">
                        <dt class="text-gray-500">Notas</dt>
                        <dd class="text-gray-700 mt-0.5">@Model.Sale.Notes</dd>
                    </div>
                }
            </dl>
        </div>

        <div class="card">
            <h3 class="text-sm font-semibold text-gray-700 mb-3">Datos del cliente</h3>
            <dl class="space-y-1 text-sm">
                <div class="flex justify-between">
                    <dt class="text-gray-500">Nombre</dt>
                    <dd class="font-medium">@Model.Sale.Customer.FirstName @Model.Sale.Customer.LastName</dd>
                </div>
                <div class="flex justify-between">
                    <dt class="text-gray-500">Documento</dt>
                    <dd>@Model.Sale.Customer.DocumentNumber</dd>
                </div>
                @if (!string.IsNullOrEmpty(Model.Sale.Customer.Phone))
                {
                    <div class="flex justify-between">
                        <dt class="text-gray-500">Teléfono</dt>
                        <dd>@Model.Sale.Customer.Phone</dd>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.Sale.Customer.Email))
                {
                    <div class="flex justify-between">
                        <dt class="text-gray-500">Email</dt>
                        <dd>@Model.Sale.Customer.Email</dd>
                    </div>
                }
            </dl>
        </div>
    </div>

    <!-- Products -->
    <div class="card p-0 overflow-hidden mb-4">
        <div class="px-4 py-3 border-b border-gray-200">
            <h3 class="text-sm font-semibold text-gray-700">Detalle de productos</h3>
        </div>
        <table class="w-full text-sm">
            <thead class="bg-gray-50 border-b border-gray-200">
                <tr>
                    <th class="text-left px-4 py-3 font-medium text-gray-600">Producto</th>
                    <th class="text-center px-4 py-3 font-medium text-gray-600">Cant.</th>
                    <th class="text-right px-4 py-3 font-medium text-gray-600">Precio Unit.</th>
                    <th class="text-right px-4 py-3 font-medium text-gray-600">Subtotal</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @foreach (var d in Model.Sale.Details)
                {
                    <tr>
                        <td class="px-4 py-3 font-medium text-gray-900">@d.Product.Name</td>
                        <td class="px-4 py-3 text-center text-gray-700">@d.Quantity</td>
                        <td class="px-4 py-3 text-right text-gray-700">$@d.UnitPrice.ToString("N2")</td>
                        <td class="px-4 py-3 text-right font-medium text-gray-900">
                            $@((d.Quantity * d.UnitPrice).ToString("N2"))
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Totals -->
    <div class="card">
        <div class="flex justify-end">
            <div class="w-64 space-y-2 text-sm">
                <div class="flex justify-between">
                    <span class="text-gray-500">Subtotal</span>
                    <span class="font-medium">$@subtotal.ToString("N2")</span>
                </div>
                <div class="flex justify-between">
                    <span class="text-gray-500">IVA (16%)</span>
                    <span class="font-medium">$@iva.ToString("N2")</span>
                </div>
                <div class="flex justify-between border-t border-gray-200 pt-2">
                    <span class="font-bold text-gray-900">Total</span>
                    <span class="font-bold text-indigo-700 text-base">$@total.ToString("N2")</span>
                </div>
            </div>
        </div>
    </div>
</div>
