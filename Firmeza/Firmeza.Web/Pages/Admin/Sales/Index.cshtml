@page
@model Firmeza.Web.Pages.Admin.Sales.IndexModel
@{
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Ventas";
}

<div class="flex items-center justify-between mb-6">
    <p class="text-sm text-gray-500">@Model.Sales.Count venta(s) registrada(s)</p>
    <div class="flex gap-2">
        <a asp-page="Index" asp-page-handler="ExportExcel"
           class="btn-secondary text-sm">Exportar Excel</a>
        <a asp-page="Create" class="btn-primary">+ Nueva venta</a>
    </div>
</div>

<div class="card p-0 overflow-hidden">
    <table class="w-full text-sm">
        <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
                <th class="text-left px-4 py-3 font-medium text-gray-600"># Venta</th>
                <th class="text-left px-4 py-3 font-medium text-gray-600">Fecha</th>
                <th class="text-left px-4 py-3 font-medium text-gray-600">Cliente</th>
                <th class="text-center px-4 py-3 font-medium text-gray-600">Estado</th>
                <th class="text-right px-4 py-3 font-medium text-gray-600">Total</th>
                <th class="px-4 py-3"></th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
            @foreach (var sale in Model.Sales)
            {
                var receiptPath = Model.GetReceiptPath(sale);
                <tr class="hover:bg-gray-50 transition-colors">
                    <td class="px-4 py-3 font-mono text-gray-700">#@sale.Id.ToString("D6")</td>
                    <td class="px-4 py-3 text-gray-600">@sale.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                    <td class="px-4 py-3 font-medium text-gray-900">
                        @sale.Customer.FirstName @sale.Customer.LastName
                        <span class="text-xs text-gray-400 ml-1">@sale.Customer.DocumentNumber</span>
                    </td>
                    <td class="px-4 py-3 text-center">
                        <span class="@(sale.Status == "Completado" ? "badge-active" : "badge-inactive")">
                            @sale.Status
                        </span>
                    </td>
                    <td class="px-4 py-3 text-right font-medium text-gray-900">$@sale.Total.ToString("N2")</td>
                    <td class="px-4 py-3">
                        <div class="flex gap-2 justify-end">
                            <a asp-page="Details" asp-route-id="@sale.Id"
                               class="text-indigo-600 hover:text-indigo-800 text-xs font-medium">Ver</a>
                            @if (!string.IsNullOrEmpty(receiptPath))
                            {
                                <a href="@receiptPath" target="_blank"
                                   class="text-green-600 hover:text-green-800 text-xs font-medium">PDF</a>
                            }
                        </div>
                    </td>
                </tr>
            }
            @if (!Model.Sales.Any())
            {
                <tr>
                    <td colspan="6" class="px-4 py-8 text-center text-gray-400">
                        No hay ventas registradas.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
