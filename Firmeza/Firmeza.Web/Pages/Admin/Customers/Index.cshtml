@page
@model Firmeza.Web.Pages.Admin.Customers.IndexModel
@{
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Clientes";
}

<div class="flex items-center justify-between mb-6">
    <p class="text-sm text-gray-500">@Model.Customers.Count cliente(s) encontrado(s)</p>
    <a asp-page="Create" class="btn-primary">+ Nuevo cliente</a>
</div>

<form method="get" class="card mb-6">
    <div class="flex gap-4">
        <input type="text" name="search" value="@Model.SearchTerm"
               placeholder="Buscar por nombre o documento..."
               class="form-input flex-1" />
        <button type="submit" class="btn-primary">Buscar</button>
        @if (!string.IsNullOrEmpty(Model.SearchTerm))
        {
            <a asp-page="Index" class="btn-secondary">Limpiar</a>
        }
    </div>
</form>

@if (Model.ErrorMessage != null)
{
    <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700">@Model.ErrorMessage</div>
}

<div class="card p-0 overflow-hidden">
    <table class="w-full text-sm">
        <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
                <th class="text-left px-4 py-3 font-medium text-gray-600">Nombre</th>
                <th class="text-left px-4 py-3 font-medium text-gray-600">Documento</th>
                <th class="text-left px-4 py-3 font-medium text-gray-600">Correo</th>
                <th class="text-left px-4 py-3 font-medium text-gray-600">Teléfono</th>
                <th class="text-center px-4 py-3 font-medium text-gray-600">Estado</th>
                <th class="px-4 py-3"></th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
            @foreach (var c in Model.Customers)
            {
                <tr class="hover:bg-gray-50 transition-colors">
                    <td class="px-4 py-3 font-medium text-gray-900">@c.FirstName @c.LastName</td>
                    <td class="px-4 py-3 text-gray-600">@c.DocumentNumber</td>
                    <td class="px-4 py-3 text-gray-600">@c.Email</td>
                    <td class="px-4 py-3 text-gray-600">@c.Phone</td>
                    <td class="px-4 py-3 text-center">
                        @if (c.IsActive)
                        {
                            <span class="badge-active">Activo</span>
                        }
                        else
                        {
                            <span class="badge-inactive">Inactivo</span>
                        }
                    </td>
                    <td class="px-4 py-3">
                        <div class="flex gap-2 justify-end">
                            <a asp-page="Edit" asp-route-id="@c.Id"
                               class="text-indigo-600 hover:text-indigo-800 text-xs font-medium">Editar</a>
                            <a asp-page="Delete" asp-route-id="@c.Id"
                               class="text-red-500 hover:text-red-700 text-xs font-medium">Eliminar</a>
                        </div>
                    </td>
                </tr>
            }
            @if (!Model.Customers.Any())
            {
                <tr>
                    <td colspan="6" class="px-4 py-8 text-center text-gray-400">No se encontraron clientes.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
