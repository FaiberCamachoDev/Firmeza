# Copiar este archivo como .env y completar los valores ANTES de ejecutar docker compose.
# NUNCA commitear el archivo .env con valores reales.

# ── Base de datos PostgreSQL ──────────────────────────────────────────────────
POSTGRES_PASSWORD=cambia_esta_password_db

# ── JWT (mínimo 32 caracteres) ────────────────────────────────────────────────
JWT_KEY=cambia_esta_clave_jwt_minimo_32_caracteres_aqui

# ── Contraseña del usuario administrador inicial ──────────────────────────────
FIRMEZA_ADMIN_PASSWORD=CambiaEstaPass@2026!

# ── Email (opcional — si está vacío se omiten los correos) ───────────────────
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=tu_correo@gmail.com
EMAIL_PASSWORD=tu_app_password_de_gmail
EMAIL_FROM=tu_correo@gmail.com
